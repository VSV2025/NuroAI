# Copy this file to ".env" and adjust if needed.

# Local MongoDB (default — works after you install MongoDB Community Server):
MONGODB_URI=mongodb://localhost:27017

# OR a free MongoDB Atlas cloud cluster (paste your connection string):
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# Database name to use inside MongoDB:
MONGODB_DB=nuroai
